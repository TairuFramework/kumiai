{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build:js": {
      "dependsOn": ["^build:js"],
      "outputs": ["lib/**/*.js"]
    },
    "build:types": {
      "dependsOn": ["^build:types"],
      "outputs": ["lib/**/*.d.ts"]
    },
    "test:types": {
      "dependsOn": ["^build:types"]
    },
    "test:unit": {
      "dependsOn": ["^build:js", "^build:types"]
    }
  }
}
