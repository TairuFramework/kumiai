{
  "name": "@kumiai/rpc-conformance",
  "version": "0.3.0",
  "license": "MIT",
  "description": "Conformance test suite for the @kumiai/rpc GroupCrypto and GroupMLS consumer ports",
  "keywords": [
    "rpc",
    "mls",
    "conformance",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/kumiai",
    "directory": "packages/rpc-conformance"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit --skipLibCheck -p tsconfig.test.json",
    "test": "pnpm run test:types",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "vitest": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
