{
  "name": "@kumiai/hub-server",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Hub server for Enkaku E2EE group message routing",
  "keywords": [
    "hub",
    "server",
    "e2ee",
    "routing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/kumiai",
    "directory": "packages/hub-server"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit --skipLibCheck -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test": "pnpm run test:types && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sozai/codec": "^0.1.0",
    "@sozai/event": "^0.1.0",
    "@kumiai/mls": "workspace:^",
    "@kumiai/hub-protocol": "workspace:^",
    "@enkaku/protocol": "^0.18.0",
    "@enkaku/server": "^0.18.0",
    "@sozai/stream": "^0.1.0",
    "@kokuin/token": "^0.1.0"
  },
  "devDependencies": {
    "@enkaku/client": "^0.18.0",
    "@enkaku/transport": "^0.18.0"
  }
}
