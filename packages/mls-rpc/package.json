{
  "name": "@kumiai/mls-rpc",
  "version": "0.3.1",
  "license": "MIT",
  "description": "The @kumiai/rpc consumer ports (GroupCrypto, GroupMLS) implemented over @kumiai/mls",
  "keywords": [
    "mls",
    "rpc",
    "group",
    "e2ee"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/kumiai",
    "directory": "packages/mls-rpc"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit --skipLibCheck -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test": "pnpm run test:types && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@kokuin/token": "catalog:",
    "@kumiai/mls": "workspace:^",
    "@kumiai/rpc": "workspace:^"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
