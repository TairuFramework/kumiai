{
  "name": "@kumiai/rpc",
  "version": "0.3.1",
  "license": "MIT",
  "description": "High-level MLS-aware group RPC for Enkaku: bus broadcast/anycast/gather plus directed RPC over the pub/sub hub",
  "keywords": [
    "rpc",
    "group",
    "mls",
    "pubsub",
    "broadcast"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/kumiai",
    "directory": "packages/rpc"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit --skipLibCheck -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test": "pnpm run test:types && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@kumiai/broadcast": "workspace:^",
    "@enkaku/client": "catalog:",
    "@sozai/codec": "catalog:",
    "@kumiai/hub-protocol": "workspace:^",
    "@kumiai/hub-tunnel": "workspace:^",
    "@enkaku/protocol": "catalog:",
    "@enkaku/server": "catalog:",
    "@enkaku/transport": "catalog:",
    "@noble/hashes": "catalog:"
  },
  "devDependencies": {
    "@kumiai/hub-conformance": "workspace:^",
    "@kumiai/rpc-conformance": "workspace:^",
    "@noble/curves": "catalog:",
    "vitest": "catalog:"
  }
}
