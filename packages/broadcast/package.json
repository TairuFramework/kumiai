{
  "name": "@kumiai/broadcast",
  "version": "0.4.0",
  "description": "Generic fan-out broadcast transport and anycast client for Enkaku RPC",
  "keywords": [
    "broadcast",
    "pubsub",
    "fanout",
    "anycast",
    "rpc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/kumiai",
    "directory": "packages/broadcast"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/*"
  ],
  "scripts": {
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm run test:types && pnpm run test:unit",
    "test:types": "tsc --noEmit --skipLibCheck -p tsconfig.test.json",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@enkaku/protocol": "catalog:",
    "@enkaku/transport": "catalog:",
    "@noble/hashes": "catalog:",
    "@sozai/async": "catalog:",
    "@sozai/codec": "catalog:",
    "@sozai/runtime": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
