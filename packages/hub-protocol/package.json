{
  "name": "@kumiai/hub-protocol",
  "version": "0.3.0",
  "license": "MIT",
  "description": "Hub protocol types for Enkaku E2EE group routing",
  "keywords": [
    "hub",
    "protocol",
    "e2ee",
    "routing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/kumiai",
    "directory": "packages/hub-protocol"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit --skipLibCheck -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test": "pnpm run test:types && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sozai/event": "catalog:",
    "@enkaku/protocol": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
